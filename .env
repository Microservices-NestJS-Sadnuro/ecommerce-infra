# Products Base Data
PRODUCTS_DB_USER=postgres
PRODUCTS_DB_PASSWORD=123456
PRODUCTS_DB_NAME=productsdb
PRODUCTS_DB_PORT=5433

# Orders Base Data
ORDERS_DB_USER=postgres
ORDERS_DB_PASSWORD=123456
ORDERS_DB_NAME=ordersdb
ORDERS_DB_PORT=5432

# Node Environment
NODE_ENV=production

# Microservices Database URLs
PRODUCTS_MS_DATABASE_URL=postgresql://${PRODUCTS_DB_USER}:${PRODUCTS_DB_PASSWORD}@products-db:5432/${PRODUCTS_DB_NAME}?schema=public
ORDERS_MS_DATABASE_URL=postgresql://${ORDERS_DB_USER}:${ORDERS_DB_PASSWORD}@orders-db:5432/${ORDERS_DB_NAME}?schema=public

# Microservices Host and Port definitions
PRODUCTS_MS_HOST=products-ms
PRODUCTS_MS_PORT=3001

ORDERS_MS_HOST=orders-ms
ORDERS_MS_PORT=3002

# API Gateway
CLIENT_GATEWAY_PORT=3000